# RentFair Environment Variables

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# RentCast API (Primary rental data source)
RENTCAST_API_KEY=your-rentcast-api-key-here

# Google Gemini API (for AI explanations)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenStreetMap Nominatim (for geocoding)
# No API key required - uses free OpenStreetMap service

# Legacy API Keys (deprecated, kept for compatibility)
# RAPIDAPI_KEY=your-rapidapi-key-here
# RAPIDAPI_HOST=private-zillow.p.rapidapi.com
# OPENAI_API_KEY=your-openai-api-key-here
# MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here
# ZILLOW_API_KEY=your-zillow-api-key-here
# REALTOR_API_KEY=your-realtor-api-key-here

# Database Configuration (if needed)
DATABASE_URL=sqlite:///rentfair.db

# Cache Configuration
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
API_RATE_LIMIT=100 requests per hour
